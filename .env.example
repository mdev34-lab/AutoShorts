# Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
API_KEY=your_api_key_here
API_URL=https://gen.pollinations.ai/v1/chat/completions
IMG_URL=https://gen.pollinations.ai/image/

# API Timeouts (seconds)
API_TIMEOUT_TEXT=30
API_TIMEOUT_IMAGE=60
API_TIMEOUT_SEARCH=15
FFPROBE_TIMEOUT=30

# Model Configuration
MODEL_TEXT=nova-fast
MODEL_IMAGE=zimage

# TTS Configuration
VOICE=en-US-BrianMultilingualNeural
TTS_RATE=+20%

# Output Settings
OUTPUT_DIR=output
DEFAULT_FONT=fonts/BebasNeue-Regular.ttf
SUBTITLE_FONT_SIZE=60

# Background Processing Mode (jumpcut = default, speed = old mode)
BG_MODE=jumpcut
JUMPCUT_SEG_DUR=4.0
BG_SKIP_INTRO=25.0  # Skip first N seconds (intros/logos)

# Video Settings (FPS doesn't affect quality - use resolution for quality)
VIDEO_FPS=24
VIDEO_CODEC=libx264
AUDIO_CODEC=aac
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# Video Processing
MIN_VIDEO_DURATION=60
MAX_VIDEO_DURATION=3600
MAX_VIDEO_CUT_DURATION=300
BLUR_RADIUS=10
MAX_ZOOM_VALUE=1.15

# Encoding Settings
ENCODING_PRESET=fast
ENCODING_CRF=23
ENCODING_THREADS=4

# YouTube Settings
YOUTUBE_MAX_HEIGHT=360
YOUTUBE_FORMAT=bestvideo[height<=360]+bestaudio/best[height<=360]

# Effect Settings
CROSSFADE_TIME=0.5
START_FADE=1.0

# Additional Settings
TEMP_DIR_PREFIX=autoshorts_
STROKE_WIDTH=5
SUBTITLE_START_Y_RATIO=0.65
BOTTOM_MARGIN=150
MAX_CHARS_PER_LINE=20
LINE_SPACING=35
COLOR_TEXT=#FFFFFF
COLOR_HIGHLIGHT=#FFFF00
COLOR_STROKE=#000000
SUBTITLE_MODE=simple